<%layout("layouts/boilerplate")%>
<div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="max-width: 450px; width:100%;">

        <div class="text-center mb-4">
            <i class="fa-solid fa-user-plus fa-3x text-danger mb-3"></i>
            <h2 class="fw-bold">Create Account</h2>
            <p class="text-muted">Join WanderLust and start exploring.</p>
        </div>

        <form action="/users/signup" method="POST" novalidate class="needs-validation">

            <div class="mb-3">
                <label class="form-label fw-semibold">Username</label>
                <input
                    type="text"
                    class="form-control rounded-3"
                    name="username"
                    placeholder="Enter your username"
                    required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">UserName Required!</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Email Address</label>
                <input
                    type="email"
                    class="form-control rounded-3"
                    name="email"
                    placeholder="Enter your email"
                    required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Email Required!</div>

            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Password</label>
                <input
                    type="password"
                    class="form-control rounded-3"
                    name="password"
                    placeholder="Create a password"
                    required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Password Required!</div>

            </div>

            <button type="submit" class="btn btn-danger w-100 py-2 rounded-3 fw-semibold">
                <i class="fa-solid fa-user-plus me-2"></i>
                Sign Up
            </button>

        </form>

        <hr>

        <p class="text-center mb-0 text-muted">
            Already have an account?
            <a href="/users/login" class="text-danger text-decoration-none fw-semibold">
                Login
            </a>
        </p>

    </div>
</div>