<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-md-6 offset-md-3">
    <h2>Verify Your Email</h2>
    <p>We've sent a 6-digit OTP to your email. Please enter it below.</p>

    <form method="POST" action="/users/verify-otp">
      <div class="mb-3">
        <label class="form-label">Enter OTP</label>
        <input type="text" name="otp" class="form-control" maxlength="6" required>
      </div>
      <button type="submit" class="btn btn-danger">Verify OTP</button>
    </form>

    <form method="POST" action="/users/resend-otp" class="mt-2">
      <button type="submit" class="btn btn-link">Resend OTP</button>
    </form>
  </div>
</div>